# --- Database ---
POSTGRES_USER=commerce
POSTGRES_PASSWORD=commerce
POSTGRES_DB=commerce_ai
DATABASE_URL=postgresql+psycopg://commerce:commerce@db:5432/commerce_ai

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=change-me-in-prod-use-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=1440

# --- AI ---
# Sağlayıcı-bağımsız LLM (OpenAI-uyumlu). Boşsa AI özellikleri deterministik fallback ile çalışır.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
